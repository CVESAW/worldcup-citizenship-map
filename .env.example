# Supabase configuration.
#
# The app works WITHOUT these set — it falls back to the bundled sample dataset
# (lib/data/seed.ts). Provide them to use a live Supabase database.

# Public (browser-safe) — used by the app for read queries.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by scripts/import_players.ts to write data (bypasses RLS).
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=
